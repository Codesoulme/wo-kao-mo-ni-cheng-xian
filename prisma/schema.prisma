// 修仙模拟器 - Prisma Schema
// Engine-authority hybrid: all state changes validated by engine

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 玩家角色 - core character state
model Character {
  id              String   @id @default(cuid())
  name            String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // 基础信息
  age             Int      @default(0)        // 当前年龄（岁）
  lifespan        Int      @default(80)       // 寿元上限
  gender          String   @default("male")   // male/female

  // 修仙核心
  spiritualRoot   String   @default("none")   // 灵根: none/mixed/common/heavenly/chaos
  rootDetail      String   @default("")       // 灵根详情，如 "火木双灵根"
  realm           String   @default("mortal") // 境界: mortal/qi_refining/foundation/golden_core/nascent_soul/spirit_severing/great_vehicle/tribulation/ascension
  realmLevel      Int      @default(0)        // 当前境界内的小境界（0-9）
  cultivationExp  Int      @default(0)        // 当前境界内修为
  expToBreak      Int      @default(100)      // 突破所需修为

  // 五行倾向 (金木水火土，0-100，归一化)
  elementMetal    Int      @default(20)
  elementWood     Int      @default(20)
  elementWater    Int      @default(20)
  elementFire     Int      @default(20)
  elementEarth    Int      @default(20)

  // 基础属性
  hp              Int      @default(100)
  maxHp           Int      @default(100)
  mp              Int      @default(50)
  maxMp           Int      @default(50)
  attack          Int      @default(10)
  defense         Int      @default(5)
  speed           Int      @default(10)
  luck            Int      @default(50)       // 气运 0-100
  comprehension   Int      @default(50)       // 悟性 0-100

  // 资源
  spiritStones    Int      @default(0)        // 灵石
  reputation      Int      @default(0)        // 声望

  // 状态
  alive           Boolean  @default(true)
  ascended        Boolean  @default(false)
  causeOfDeath    String   @default("")
  faction         String   @default("")       // 宗门
  master          String   @default("")       // 师承
  location        String   @default("凡间")   // 当前所在

  // 命节点进度（已完成命节点序号列表，逗号分隔）
  fateNodes       String   @default("")
  isAtChoice      Boolean  @default(false)    // 是否处于选择节点
  lastEventAge    Int      @default(-1)       // 上次事件发生的年龄

  // JSON string of current active status entries
  statusJson      String   @default("[]")
  // JSON string of inventory items
  inventoryJson   String   @default("[]")
  // JSON string of equipped items (weapon/armor/accessory/artifact/scripture)
  equippedJson    String   @default("{}")
  // 修炼速度倍率（灵根 × 功法），default 1.0
  cultivationMultiplier Float @default(1.0)
  // JSON string of memory entries (long-term)
  memoryJson      String   @default("[]")

  events          EventLog[]
  choices         ChoiceLog[]
  interferences   InterferenceLog[]
}

// 事件日志
model EventLog {
  id           String   @id @default(cuid())
  characterId  String
  character    Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  age          Int
  title        String                       // 事件标题
  narrative    String                       // AI 生成的叙事
  eventType    String   @default("normal")  // normal/fate_node/choice/interference/combat/breakthrough/death
  effects      String   @default("[]")      // JSON: 状态变更列表
  createdAt    DateTime @default(now())

  @@index([characterId, age])
}

// 选择日志
model ChoiceLog {
  id           String   @id @default(cuid())
  characterId  String
  character    Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  age          Int
  prompt       String                       // 选择提示
  options      String                       // JSON: 选项列表
  chosenIndex  Int                          // 玩家选择的索引
  chosenText   String                       // 玩家选择的文本
  result       String                       // 选择结果叙事
  createdAt    DateTime @default(now())
}

// 玩家干扰日志
model InterferenceLog {
  id           String   @id @default(cuid())
  characterId  String
  character    Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  age          Int
  input        String                       // 玩家输入
  classification String @default("action")  // action/dialogue/overreach/rule_manipulation
  response     String                       // AI 回应叙事
  effects      String   @default("[]")      // JSON: 状态变更
  accepted     Boolean  @default(true)      // 是否被接受（false=静默拒绝）
  createdAt    DateTime @default(now())
}
